# =============================================================================
# Sztauer — environment variables
# Copy this file to .env and fill in the values.
# =============================================================================

# Anthropic API key (REQUIRED)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Project name (REQUIRED when not passed on command line)
# Used for: container name, subdomain, volumes.
# Example: PROJECT_NAME=myapp → myapp.localhost, sztauer-myapp-workspace
# PROJECT_NAME=

# Default port for {name}-app.localhost (optional, default: 8000)
# APP_PORT=8000

# Additional firewall-allowed domains (optional)
# Comma-separated. Default allowlist: Anthropic API, GitHub, npm, PyPI.
# FIREWALL_ALLOW=custom-api.example.com,another-service.io
